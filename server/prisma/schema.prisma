// Prisma schema for Kachuful multiplayer card game
// Backend-authoritative architecture with real-time Socket.IO sync

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Player model - stores player information
model Player {
  id            String   @id @default(cuid())
  name          String
  // Stable, client-generated identity that survives reconnects and new socket
  // ids. This is what we match a returning player on (socketId changes on every
  // reconnection, so it can't be used as identity).
  clientId      String?  @unique
  // The player's CURRENT live connection. Mutable: updated on (re)connect,
  // cleared on disconnect.
  socketId      String?  @unique
  isBot         Boolean  @default(false)
  botDifficulty String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  hostedLobbies Lobby[]       @relation("HostedLobbies")
  lobbyPlayers  LobbyPlayer[]
  gameActions   GameAction[]
  currentTurns  Game[]        @relation("CurrentTurnPlayer")
  roundBids     RoundBid[]

  @@index([socketId])
  @@index([clientId])
}

// Lobby model - represents a game lobby
model Lobby {
  id           String      @id @default(cuid())
  code         String      @unique @db.VarChar(6)
  hostPlayerId String
  status       LobbyStatus @default(WAITING)
  settings     Json        @default("{\"rounds\": 4, \"orderMode\": \"Kachuful\", \"scoringMode\": \"+10\", \"maxPlayers\": 8}")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  hostPlayer   Player        @relation("HostedLobbies", fields: [hostPlayerId], references: [id])
  lobbyPlayers LobbyPlayer[]
  games        Game[]

  @@index([code])
  @@index([hostPlayerId])
  @@index([status])
}

// LobbyPlayer model - junction table for players in a lobby
model LobbyPlayer {
  id           String   @id @default(cuid())
  lobbyId      String
  playerId     String
  isHost       Boolean  @default(false)
  seatPosition Int
  joinedAt     DateTime @default(now())

  // Relations
  lobby  Lobby  @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([lobbyId, playerId])
  @@unique([lobbyId, seatPosition])
  @@index([lobbyId])
  @@index([playerId])
}

// Game model - represents an active game session
model Game {
  id                  String     @id @default(cuid())
  lobbyId             String
  totalRounds         Int        @default(4)
  currentRound        Int        @default(1)
  currentHandSize     Int        @default(1)
  currentTurnPlayerId String?
  status              GameStatus @default(BIDDING)
  trumpOrderJson      Json       @default("[]")
  gameStateJson       Json       @default("{}")
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  // Relations
  lobby             Lobby        @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  currentTurnPlayer Player?      @relation("CurrentTurnPlayer", fields: [currentTurnPlayerId], references: [id])
  gameActions       GameAction[]
  gameRounds        GameRound[]
  roundBids         RoundBid[]
  roundTricks       RoundTrick[]
  roundScores       RoundScore[]
  scoreboardConfirmations ScoreboardConfirmation[]
  gameResult        GameResult?

  @@index([lobbyId])
  @@index([status])
}

// GameResult model - stores the final result of a completed game (created once)
model GameResult {
  id              String   @id @default(cuid())
  gameId          String   @unique
  winnerPlayerIds Json     // array of winning player IDs (supports ties)
  winningScore    Int
  finalScoresJson Json     // map of playerId -> total score
  createdAt       DateTime @default(now())

  // Relations
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
}

// GameRound model - represents a single round in a game
model GameRound {
  id          String      @id @default(cuid())
  gameId      String
  roundNumber Int
  handSize    Int
  trumpKey    String      // e.g., "Kari", "Chukat", "Falli", "Lal"
  trumpName   String      // Display name in Hindi/local language
  trumpSuit   String      // e.g., "spades", "diamonds", "clubs", "hearts"
  status      RoundStatus @default(BIDDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  game        Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  roundBids   RoundBid[]
  roundTricks RoundTrick[]
  roundScores RoundScore[]
  scoreboardConfirmations ScoreboardConfirmation[]

  @@unique([gameId, roundNumber])
  @@index([gameId])
  @@index([status])
}

// RoundBid model - stores player bids for each round
model RoundBid {
  id        String   @id @default(cuid())
  gameId    String
  roundId   String
  playerId  String
  bidValue  Int
  createdAt DateTime @default(now())

  // Relations
  game   Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  round  GameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  player Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([roundId, playerId])
  @@index([gameId])
  @@index([roundId])
  @@index([playerId])
}

// RoundTrick model - stores each trick in a round
model RoundTrick {
  id              String       @id @default(cuid())
  gameId          String
  roundId         String
  trickNumber     Int
  leadPlayerId    String
  leadSuit        String?
  winningPlayerId String?
  winningCardJson Json?
  status          TrickStatus  @default(ACTIVE)
  createdAt       DateTime     @default(now())
  completedAt     DateTime?

  // Relations
  game       Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  round      GameRound   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  trickCards TrickCard[]

  @@unique([roundId, trickNumber])
  @@index([gameId])
  @@index([roundId])
  @@index([status])
}

// TrickCard model - stores each card played in a trick
model TrickCard {
  id        String   @id @default(cuid())
  trickId   String
  playerId  String
  cardJson  Json
  playOrder Int
  createdAt DateTime @default(now())

  // Relations
  trick RoundTrick @relation(fields: [trickId], references: [id], onDelete: Cascade)

  @@unique([trickId, playerId])
  @@index([trickId])
  @@index([playerId])
}

// RoundScore model - stores player scores for each round
model RoundScore {
  id         String   @id @default(cuid())
  gameId     String
  roundId    String
  playerId   String
  bidValue   Int
  handsMade  Int
  roundScore Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  game  Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  round GameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([roundId, playerId])
  @@index([gameId])
  @@index([roundId])
  @@index([playerId])
}

// ScoreboardConfirmation model - tracks who has clicked Continue
model ScoreboardConfirmation {
  id          String    @id @default(cuid())
  gameId      String
  roundId     String
  playerId    String
  hasContinued Boolean  @default(false)
  continuedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  game  Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  round GameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([gameId, roundId, playerId])
  @@index([gameId])
  @@index([roundId])
  @@index([playerId])
}

// GameAction model - logs all game actions for replay/audit
model GameAction {
  id            String         @id @default(cuid())
  gameId        String
  playerId      String
  actionType    GameActionType
  actionPayload Json
  createdAt     DateTime       @default(now())

  // Relations
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([playerId])
  @@index([actionType])
  @@index([createdAt])
}

// Enums
enum LobbyStatus {
  WAITING
  IN_GAME
  COMPLETED
}

enum GameStatus {
  BIDDING
  PLAYING
  HAND_WINNER
  ROUND_COMPLETE
  ROUND_SCOREBOARD
  GAME_OVER
  FINAL_WINNER
  COMPLETED
}

enum RoundStatus {
  BIDDING
  PLAYING
  COMPLETED
}

enum TrickStatus {
  ACTIVE
  COMPLETED
}

enum GameActionType {
  BID_SUBMIT
  CARD_PLAY
  ROUND_START
  ROUND_END
  GAME_START
  GAME_END
}
