# ---------------------------------------------------------------------------
# Game server environment. Copy to `.env` for local dev; set these as real
# environment variables in your host (Railway / Render / Fly) for production.
# ---------------------------------------------------------------------------

# Port the HTTP + WebSocket server listens on.
# Locally 3001. In production most hosts inject PORT automatically.
PORT=3001

# development | production
NODE_ENV=development

# PostgreSQL connection string.
#   Local : postgresql://postgres:pass1234@localhost:5432/judgement?schema=public
#   Neon  : use the POOLED connection string from the Neon dashboard, e.g.
#           postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL="postgresql://postgres:pass1234@localhost:5432/judgement?schema=public"

# CORS allow-list for the REST API and Socket.IO handshake.
#   "*"                      -> allow any origin (fine for native apps only)
#   "https://play.you.com"   -> single browser origin
#   "https://a.com,https://b.com" -> multiple origins (comma-separated)
# Native (iOS/Android) clients don't send an Origin header, so "*" is harmless
# for them. Lock this down once you have a web build.
CORS_ORIGIN=*

# Performance instrumentation (optional; off unless set). When enabled, logs
# socket transport, per-handler timing, and broadcast payload sizes.
# PERF_LOG=1
# PERF_WARN_MS=100   # handlers slower than this are logged as SLOW
