# ---------------------------------------------------------------------------
# Expo client environment (project root). Copy to `.env` and adjust.
# Only EXPO_PUBLIC_* vars are exposed to the app bundle.
# ---------------------------------------------------------------------------

# Base URL of the game server the app connects to (REST + Socket.IO).
#   iOS simulator / web : http://localhost:3001  (or leave unset)
#   Android emulator    : http://10.0.2.2:3001
#   Physical device     : http://<your-LAN-IP>:3001   e.g. http://192.168.0.21:3001
#   Production          : https://your-api-host        (MUST be https)
EXPO_PUBLIC_SERVER_URL=http://localhost:3001
